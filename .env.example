# podcast-llm-wiki secrets. Copy to .env (gitignored) and fill in.
#
# HF_TOKEN is only required for pyannote speaker diarization
# (`diarization: true` in podcasts.yaml). Transcription with faster-whisper
# does not need a token.
#
# Get a token at https://huggingface.co/settings/tokens after accepting the
# pyannote/speaker-diarization-3.1 license at
# https://huggingface.co/pyannote/speaker-diarization-3.1.
HF_TOKEN=

# Optional: pin transcription to a specific GPU. Useful on multi-GPU hosts
# where one card is shared with other workloads or is an older architecture
# unsupported by the installed torch build. Set CUDA_DEVICE_ORDER=PCI_BUS_ID
# in the shell env or systemd unit so these indices match nvidia-smi.
CUDA_VISIBLE_DEVICES=
